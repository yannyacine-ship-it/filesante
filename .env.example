# ============================================
# FILESANTÉ - Configuration Environnement
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# Environnement
NODE_ENV=development
PORT=3000

# Base de données PostgreSQL
DATABASE_URL=postgresql://filesante:password@localhost:5432/filesante
DB_HOST=localhost
DB_PORT=5432
DB_NAME=filesante
DB_USER=filesante
DB_PASSWORD=your_secure_password

# Redis (pour cache et sessions)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=24h

# Twilio SMS
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# URLs
FRONTEND_URL=http://localhost:8080
API_URL=http://localhost:3000

# TTL Configuration (en millisecondes)
TTL_PENDING=7200000       # 2 heures
TTL_WAITING=43200000      # 12 heures
TTL_NOTIFIED=10800000     # 3 heures
TTL_RETURNED=3600000      # 1 heure
TTL_NOSHOW=86400000       # 24 heures

# Seuils d'alerte (en millisecondes)
ALERT_OVERDUE=21600000    # 6 heures
ALERT_ESCALATE=28800000   # 8 heures
NOTIFY_BEFORE=2700000     # 45 minutes

# Jobs de maintenance (cron expressions)
CRON_CLEANUP=*/15 * * * *     # Toutes les 15 minutes
CRON_DAILY_RESET=0 6 * * *    # Tous les jours à 6h
CRON_ESCALATION=*/30 * * * *  # Toutes les 30 minutes

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # 100 requêtes par fenêtre

# Logging
LOG_LEVEL=info
LOG_FILE=logs/filesante.log
